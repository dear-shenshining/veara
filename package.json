{
  "name": "veara-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:poll": "powershell -NoProfile -Command \"$env:WATCHPACK_POLLING='true'; $env:CHOKIDAR_USEPOLLING='true'; npx next dev --webpack\"",
    "dev:stop": "powershell -NoProfile -Command \"if (Test-Path '.next/dev/lock') { try { Stop-Process -Id ((Get-Content '.next/dev/lock' -Raw | ConvertFrom-Json).pid) -Force -ErrorAction SilentlyContinue } catch {} }\"",
    "dev:clean": "npm run dev:stop && npm run dev:clean:cache && npm run dev",
    "dev:clean:cache": "powershell -NoProfile -Command \"if (Test-Path .next) { Remove-Item -Recurse -Force .next }\"",
    "build": "next build --webpack",
    "start": "next start",
    "preview": "npm run build && npm run start",
    "lint": "eslint"
  },
  "dependencies": {
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
